# Plannert environment variables

# PostgreSQL connection string (Prisma).
# Leave empty to use the built-in local JSON file store for development.
#
# For a zero-dependency local Postgres, this repo ships a project-local cluster
# in ./.pgdata on port 5433. Start it with `npm run db:start` and use:
DATABASE_URL="postgresql://postgres@localhost:5433/plannert?schema=public"

# Free AI provider — Google Gemini (Vercel AI SDK).
# Get a key at https://aistudio.google.com/app/apikey
# Leave empty to use the built-in deterministic fallback (no AI key required).
GOOGLE_GENERATIVE_AI_API_KEY=""
